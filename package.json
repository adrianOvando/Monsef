{
  "name": "monitoreo-rs-sucre-root",
  "version": "1.0.0",
  "description": "Root package manager for MonitoreoRS Sucre",
  "private": true,
  "scripts": {
    "db:setup": "npm --prefix backend run db:setup",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:seed": "npm --prefix backend run db:seed",
    "backend:start": "npm --prefix backend start",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:dev": "npm --prefix frontend run dev"
  }
}
